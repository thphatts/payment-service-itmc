# Database Configuration
DB_PASSWORD=your_db_password_here

# Redis Configuration
REDIS_PASSWORD=your_redis_password_here

# PayOS Configuration (Get from dashboard.payos.vn)
PAYOS_CLIENT_ID=your_client_id
PAYOS_API_KEY=your_api_key
PAYOS_CHECKSUM_KEY=your_checksum_key

# Webhook Secret (Custom)
WEBHOOK_SECRET=your_custom_webhook_secret

# Ngrok Configuration (Get authtoken from dashboard.ngrok.com)
# Required for receiving PayOS webhooks on localhost
NGROK_AUTHTOKEN=your_ngrok_authtoken_here

# Club Information (Optional)
BANK_ID=
BANK_ACCOUNT_NO=your_account_no
BANK_ACCOUNT_NAME=your_account_name
